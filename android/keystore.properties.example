# Copy this to android/keystore.properties and fill in real values.
# The real file is gitignored and must never be committed.
#
# storeFile     — absolute path to your .jks upload keystore
# storePassword — password for the keystore file
# keyAlias      — alias passed to keytool -alias (for us: loyalink-upload)
# keyPassword   — password for the key itself. If you reused the keystore
#                 password when keytool asked (by pressing Enter), set this
#                 to the same value as storePassword.
storeFile=/Users/simonsevelsted/Documents/loyalink-upload.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=loyalink-upload
keyPassword=YOUR_KEY_PASSWORD
